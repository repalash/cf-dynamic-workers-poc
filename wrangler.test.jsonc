// Test-only wrangler config. Mirrors wrangler.jsonc but adds the `directory`
// field required by wrangler's parser when `assets` is present (the vite
// plugin normally supplies this at dev/build time; in the vitest pool the
// config is parsed directly). Used by vitest.config.ts.
{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cf-dynamic-workers-poc",
  "main": "src/server/worker.ts",
  "compatibility_date": "2026-01-28",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist/client",
    "not_found_handling": "single-page-application",
    "run_worker_first": true
  },
  "worker_loaders": [
    { "binding": "LOADER" }
  ],
  "d1_databases": [
    {
      "binding": "TEENY_PRIMARY_DB",
      "database_name": "cf-dynamic-workers-poc-db",
      "database_id": "00000000-0000-0000-0000-000000000000"
    }
  ],
  "vars": {
    "MIGRATE_UI_USER": "admin"
  }
}
